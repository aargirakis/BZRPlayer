     <string notr="true">
QWidget
{
border-color:#ff2828;
selection-background-color: #333333/*selection*/;
selection-color: #ffffff/*main text*/;
font-family:Roboto;
font-size:14px;
background-color:#282828/*background*/;
color:#ffffff/*main text*/;
}
QTextEdit {
    border: 1px solid;
	border-color:#009379/*main*/; 
    border-radius: 3px;
    padding: 1px 18px 1px 3px;
    min-width: 6em;
}

QSlider::groove:horizontal { 
	background-color: #404040/*medium*/;
	height: 4px; 
	border-radius: 4px;
}
QSlider::handle:horizontal { 
	background-color: #009379/*main*/; 
	border: 2px solid #009379/*main*/; 
	width: 11px; 
	height: 20px; 
	line-height: 20px; 
	margin-top: -5px; 
	margin-bottom: -5px; 
	border-radius: 7px; 
}
QSlider::handle:horizontal:hover { 
	background-color: #00c09e/*main hover*/; 
	border: 2px solid #00c09e/*main hover*/; 
}

QSlider::sub-page:horizontal {
background-color:#009379/*main*/; 
}
QComboBox {
    border: 1px solid;
	border-color: #009379/*main*/; 
    border-radius: 3px;
    padding: 1px 18px 1px 3px;
}

QComboBox:editable {
    background: #333;
}

QComboBox:!editable, QComboBox::drop-down:editable {
     background: ;
}

/* QComboBox gets the &quot;on&quot; state when the popup is open */
QComboBox:!editable:on, QComboBox::drop-down:editable:on {
    background: qlineargradient(x1: 0, y1: 0, x2: 0, y2: 1,
                                stop: 0 #D3D3D3, stop: 0.4 #D8D8D8,
                                stop: 0.5 #DDDDDD, stop: 1.0 #E1E1E1);
}

QComboBox:on { /* shift the text when the popup opens */
    padding-top: 3px;
    padding-left: 4px;
}

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 15px;

    border-left-width: 1px;
    border-left-color: #009379/*main*/; 
    border-left-style: solid; /* just a single line */
    border-top-right-radius: 3px; /* same radius as the QComboBox */
    border-bottom-right-radius: 3px;
}
QComboBox QAbstractItemView {
    border: 1px solid;
	border-color: #009379/*main*/; 
    background-color:#282828/*background*/;
	outline:none;
}

QComboBox::down-arrow:on { /* shift the arrow when popup is open */
    top: 1px;
    left: 1px;
}

QLineEdit {
    border: 1px solid;
	border-color:#009379/*main*/; 
    border-radius: 3px;
    padding: 1px 18px 1px 3px;
    min-width: 6em;
}

QWidget:disabled
{
color:#404040/*medium*/;

}
QPushButton
{
font-family:roboto;
background-color: #b7b7b7/*button*/;
border-radius: 12px;
padding:4px;
font-size:14px;
color:#282828/*background*/;
}
QPushButton:hover
{
background-color: #ffffff/*button hover*/;
}
QSlider::handle:disabled {
	background-color: #404040/*medium*/;
	border: 2px solid #404040/*medium*/;
}
QSlider::sub-page:horizontal:disabled {
background-color:#404040/*medium*/;
}
QComboBox:disabled {
    border: 1px solid #404040/*medium*/;

}
QComboBox::drop-down:disabled {

    border-left-color: #404040/*medium*/;

}
     </string>
    </property>
